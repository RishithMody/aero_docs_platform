{
  "name": "aerodocs-platform",
  "private": true,
  "workspaces": [
    "apps/*"
  ],
  "scripts": {
    "dev:web": "npm run dev --workspace=web",
    "build:web": "npm run build --workspace=web",
    "dev:api": "cd backend && uvicorn app.main:app --reload --port 8080",
    "dev:ollama": "docker compose up -d ollama && npm run models:pull",
    "docker:up": "docker compose up --build",
    "docker:down": "docker compose down",
    "models:pull": "bash docker/pull-models.sh",
    "test:unit": "cd backend && python -m pytest -m 'not integration'",
    "test:integration": "cd backend && python -m pytest -m integration",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui"
  },
  "devDependencies": {
    "@playwright/test": "^1.49.0"
  },
  "engines": {
    "node": ">=20"
  }
}
